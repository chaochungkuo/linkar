{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linkar.dev/schemas/linkar-template.schema.json",
  "title": "Linkar Template",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "run"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "params": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["str", "int", "float", "bool", "path", "list[path]"]
          },
          "required": {
            "type": "boolean"
          },
          "default": {}
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry", "mode"],
      "properties": {
        "entry": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["direct", "render"]
        }
      }
    }
  }
}
