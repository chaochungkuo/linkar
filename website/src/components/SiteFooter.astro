---
const base = import.meta.env.BASE_URL;
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a class="brand footer-brand-link" href={base}>
        <span class="brand-mark">lk</span>
        <span class="brand-word">linkar</span>
      </a>
      <p class="footer-tagline">Reusable analysis templates for humans and machines.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <div class="footer-nav-group">
        <p class="footer-nav-heading">Docs</p>
        <a href={`${base}explanations/`}>Concepts</a>
        <a href={`${base}tutorials/`}>Tutorials</a>
        <a href={`${base}examples/`}>Examples</a>
      </div>
      <div class="footer-nav-group">
        <p class="footer-nav-heading">Project</p>
        <a href="https://github.com/chaochungkuo/linkar" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://github.com/chaochungkuo/linkar/issues" target="_blank" rel="noopener noreferrer">Issues</a>
        <a href="https://github.com/chaochungkuo/linkar/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">License</a>
      </div>
    </nav>
  </div>

  <div class="footer-bottom">
    <p>MIT licensed &middot; <a href="https://github.com/chaochungkuo/linkar" target="_blank" rel="noopener noreferrer">chaochungkuo/linkar</a></p>
  </div>
</footer>
