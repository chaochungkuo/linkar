---
import SiteNav from "./SiteNav.astro";
---

<header class="hero">
  <SiteNav />

  <div class="hero-grid">
    <div class="hero-copy">
      <div class="hero-badges">
        <span class="hero-badge">Filesystem-first runtime</span>
        <span class="hero-badge">CLI + local API</span>
        <span class="hero-badge">Agent-ready metadata</span>
      </div>
      <p class="eyebrow">Reusable computational work, without a workflow language</p>
      <h1 class="hero-title">A high-trust runtime for templates, humans, and agents.</h1>
      <p class="lede">
        Linkar sits between ad hoc scripts and heavyweight workflow systems. It gives teams a
        short human CLI, a machine-readable local API, portable run artifacts, and enough structure
        for AI agents to use reliably without shell scraping.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={`${import.meta.env.BASE_URL}tutorials/getting-started/`}>Start Here</a>
        <a class="button button-secondary" href={`${import.meta.env.BASE_URL}tutorials/using-linkar-from-agents/`}>For Agents</a>
      </div>
      <div class="hero-metrics">
        <div class="metric-card">
          <strong>1 runtime</strong>
          <span>CLI, core, and API share the same execution semantics.</span>
        </div>
        <div class="metric-card">
          <strong>0 hidden state</strong>
          <span>Runs stay on disk as normal directories with inspectable metadata.</span>
        </div>
      </div>
    </div>

    <div class="hero-panel">
      <div class="terminal-window">
        <div class="terminal-bar">
          <span></span><span></span><span></span>
        </div>
        <pre><code>$ linkar project init --name study
cd study

$ linkar pack add ~/github/izkf_genomics_pack --id izkf
$ linkar run fastqc --input sample.fastq.gz
$ linkar run multiqc
$ linkar inspect run multiqc_001

study/
  multiqc_001/
    results/
    .linkar/
      meta.json
      runtime.json</code></pre>
      </div>
    </div>
  </div>
</header>
