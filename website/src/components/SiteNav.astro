---
const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;

const navItems = [
  { href: `${base}explanations/`, label: "Concepts" },
  { href: `${base}tutorials/`, label: "Tutorials" },
  { href: `${base}examples/`, label: "Examples" },
];

function isActive(href: string) {
  if (href === `${base}`) {
    return pathname === href;
  }
  return pathname === href || pathname.startsWith(href);
}
---

<nav class="topbar">
  <a class="brand" href={base}>
    <span class="brand-mark">lk</span>
    <span class="brand-word">linkar</span>
  </a>
  <div class="topbar-actions">
    <div class="nav-links">
      {
        navItems.map((item) => (
          <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
            {item.label}
          </a>
        ))
      }
    </div>
    <a class="github-link" href="https://github.com/chaochungkuo/linkar" target="_blank" rel="noopener noreferrer" aria-label="View on GitHub">
      <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor" width="18" height="18">
        <path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.184 6.839 9.504.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.026 2.747-1.026.546 1.378.202 2.397.1 2.65.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482C19.138 20.2 22 16.447 22 12.021 22 6.484 17.523 2 12 2z"/>
      </svg>
      GitHub
    </a>
    <button class="theme-toggle" type="button" aria-label="Toggle color theme" data-theme-toggle>
      Theme
    </button>
  </div>
  <script is:inline>
    (() => {
      const storageKey = "linkar-theme";
      const root = document.documentElement;
      const button = document.querySelector("[data-theme-toggle]");
      if (!button) return;

      const applyLabel = () => {
        const theme = root.dataset.theme === "dark" ? "dark" : "light";
        button.textContent = theme === "dark" ? "Light" : "Dark";
        button.setAttribute("aria-pressed", theme === "dark" ? "true" : "false");
      };

      applyLabel();
      button.addEventListener("click", () => {
        const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
        root.dataset.theme = nextTheme;
        localStorage.setItem(storageKey, nextTheme);
        applyLabel();
      });
    })();
  </script>
</nav>
