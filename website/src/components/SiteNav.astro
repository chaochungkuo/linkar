---
const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;

const navItems = [
  { href: `${base}explanations/`, label: "Concepts" },
  { href: `${base}tutorials/`, label: "Tutorials" },
  { href: `${base}examples/`, label: "Examples" },
];

function isActive(href: string) {
  if (href === `${base}`) {
    return pathname === href;
  }
  return pathname === href || pathname.startsWith(href);
}
---

<nav class="topbar">
  <a class="brand" href={base}>
    <span class="brand-mark">lk</span>
    <span class="brand-word">linkar</span>
  </a>
  <div class="topbar-actions">
    <div class="nav-links">
      {
        navItems.map((item) => (
          <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
            {item.label}
          </a>
        ))
      }
    </div>
    <button class="theme-toggle" type="button" aria-label="Toggle color theme" data-theme-toggle>
      Theme
    </button>
  </div>
  <script is:inline>
    (() => {
      const storageKey = "linkar-theme";
      const root = document.documentElement;
      const button = document.querySelector("[data-theme-toggle]");
      if (!button) return;

      const applyLabel = () => {
        const theme = root.dataset.theme === "dark" ? "dark" : "light";
        button.textContent = theme === "dark" ? "Light" : "Dark";
        button.setAttribute("aria-pressed", theme === "dark" ? "true" : "false");
      };

      applyLabel();
      button.addEventListener("click", () => {
        const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
        root.dataset.theme = nextTheme;
        localStorage.setItem(storageKey, nextTheme);
        applyLabel();
      });
    })();
  </script>
</nav>
