---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";

const explanations = (await getCollection("explanations")).sort((a, b) => a.data.order - b.data.order);
const explanationHref = (slug: string) => `${import.meta.env.BASE_URL}explanations/${slug}/`;
---

<BaseLayout title="Concepts | Linkar" description="Understand the core ideas behind Linkar: reusable templates, reusable bindings, portable packs, readable projects, and human-plus-machine interfaces.">
  <div class="page-shell">
    <SiteNav />
    <main class="section-page">
      <section class="page-hero">
        <p class="eyebrow">Concepts</p>
        <h1 class="page-title">The model behind Linkar.</h1>
        <p class="lede page-lede">
          Start here if you want to understand what Linkar is for. These pages explain the tension
          between customization and reuse, the role of templates and bindings, and why packs and
          projects are intentionally separate.
        </p>
      </section>

      <section class="section page-section-tight">
        <div class="card-grid two-up">
          {explanations.map((entry) => (
            <a class="doc-card" href={explanationHref(entry.slug)}>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
