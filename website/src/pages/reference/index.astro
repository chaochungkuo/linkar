---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";

const explanations = (await getCollection("explanations")).sort((a, b) => a.data.order - b.data.order);
const explanationHref = (slug: string) => `${import.meta.env.BASE_URL}explanations/${slug}/`;
---

<BaseLayout title="Reference | Linkar" description="Read the current Linkar explanations and runtime reference pages that define the product model and contract.">
  <div class="page-shell">
    <SiteNav />
    <main class="section-page">
      <section class="page-hero">
        <p class="eyebrow">Reference</p>
        <h1 class="page-title">Specs and rationale in one place.</h1>
        <p class="lede page-lede">
          Linkar stays readable all the way down. The public pages explain the model, and the
          development docs define the contract in more detail.
        </p>
      </section>

      <section class="section page-section-tight">
        <div class="split-grid">
          <article class="content-card">
            <h3>Read this in order</h3>
            <p>
              Start with the explanations if you want the product boundary first. The current
              runtime contract now lives here in the website, not in a separate development-docs
              tree.
            </p>
          </article>
          <article class="content-card">
            <h3>What this section is for</h3>
            <p>
              These pages are the current truth for runtime behavior, pack conventions, render/run
              semantics, metadata, and interface boundaries.
            </p>
          </article>
        </div>
      </section>

      <section class="section page-section-tight">
        <div class="section-heading">
          <p class="eyebrow">Explanations</p>
          <h2>Product-level rationale.</h2>
        </div>
        <div class="card-grid two-up">
          {explanations.map((entry) => (
            <a class="doc-card" href={explanationHref(entry.slug)}>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description}</p>
            </a>
          ))}
        </div>
      </section>

    </main>
  </div>
</BaseLayout>
