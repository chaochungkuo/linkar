---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";

const explanations = (await getCollection("explanations")).sort((a, b) => a.data.order - b.data.order);
const explanationHref = (slug: string) => `${import.meta.env.BASE_URL}explanations/${slug}/`;
---

<BaseLayout title="Reference | Linkar" description="Read the runtime contracts behind Linkar: pack conventions, template semantics, parameter resolution, metadata, and public interfaces.">
  <div class="page-shell">
    <SiteNav />
    <main class="section-page">
      <section class="page-hero">
        <p class="eyebrow">Reference</p>
        <h1 class="page-title">Specs and rationale in one place.</h1>
        <p class="lede page-lede">
          Use this section when you already understand the model and need the concrete contract:
          template runtime rules, output collection, parameter resolution, metadata, and interface
          behavior.
        </p>
      </section>

      <section class="section page-section-tight">
        <div class="split-grid">
          <article class="content-card">
            <h3>Read this in order</h3>
            <p>
              Start with the concepts if you want the product boundary first. Then use the
              explanation pages here as the durable reference for how Linkar behaves.
            </p>
          </article>
          <article class="content-card">
            <h3>What this section is for</h3>
            <p>
              These pages are the reference for runtime behavior, pack conventions,
              render-versus-run semantics, metadata, bindings, and interface boundaries.
            </p>
          </article>
        </div>
      </section>

      <section class="section page-section-tight">
        <div class="section-heading">
          <p class="eyebrow">Explanations</p>
          <h2>Product-level rationale.</h2>
        </div>
        <div class="card-grid two-up">
          {explanations.map((entry) => (
            <a class="doc-card" href={explanationHref(entry.slug)}>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description}</p>
            </a>
          ))}
        </div>
      </section>

    </main>
  </div>
</BaseLayout>
