---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";

const tutorials = (await getCollection("tutorials")).sort((a, b) => a.data.order - b.data.order);
const explanations = (await getCollection("explanations")).sort((a, b) => a.data.order - b.data.order);
const tutorialHref = (slug: string) => `${import.meta.env.BASE_URL}tutorials/${slug}/`;
const explanationHref = (slug: string) => `${import.meta.env.BASE_URL}explanations/${slug}/`;
---

<BaseLayout
  title="Linkar | Template Runtime For Humans And Agents"
  description="Linkar is a lightweight runtime for reusable computational templates, with a human-friendly CLI, a local API, and transparent run artifacts designed for reliable AI-agent use."
>
  <div class="page-shell">
    <SiteHeader />

    <main>
      <section class="section">
        <div class="section-heading">
          <p class="eyebrow">Why Linkar</p>
          <h2>A runtime for the work between scripts and workflow engines.</h2>
          <p class="section-copy">
            Linkar keeps one computational step reusable, inspectable, and easy to run. It does
            not ask you to adopt a workflow language just to make a script portable.
          </p>
        </div>

        <div class="card-grid three-up">
          <article class="feature-card">
            <h3>Templates stay standalone</h3>
            <p>
              Each template is a normal directory with a small YAML contract and a real entry
              script. Nothing important is hidden in framework internals.
            </p>
          </article>
          <article class="feature-card">
            <h3>Humans get a short CLI</h3>
            <p>
              The common path stays short: discover the current project, expose template params as
              flags, and write readable run artifacts instead of hidden state.
            </p>
          </article>
          <article class="feature-card">
            <h3>Agents get explicit structure</h3>
            <p>
              Every run lives in a normal directory with <code>results/</code>,
              <code>.linkar/meta.json</code>, and runtime details that tools and agents can inspect
              later without shell scraping.
            </p>
          </article>
        </div>
      </section>

      <section class="section section-dark">
        <div class="section-heading">
          <p class="eyebrow">Interfaces</p>
          <h2>One runtime, two clear interfaces.</h2>
          <p class="section-copy">
            Humans get a short CLI. Agents get a structured core and local API. Both write the same
            run artifact on disk.
          </p>
        </div>

        <div class="interface-grid">
          <article class="interface-card">
            <div class="interface-head">
              <span class="interface-tag">Human</span>
              <h3>Short CLI for real work</h3>
            </div>
            <p>
              Discover the current project, expose template params as flags, and keep the command
              path short enough to use every day.
            </p>
            <pre><code>linkar project init --name study
cd study
linkar run fastqc --input sample.fastq.gz
linkar project runs
linkar inspect run fastqc_001</code></pre>
          </article>

          <article class="interface-card">
            <div class="interface-head">
              <span class="interface-tag">Machine</span>
              <h3>Structured API for agents</h3>
            </div>
            <p>
              Inspect templates, run work, and consume outputs through JSON while still writing the
              same on-disk artifacts.
            </p>
            <pre><code>linkar serve --port 8000

GET  /templates
GET  /templates/&lcub;template_id&rcub;
POST /resolve
POST /run
GET  /runs/&lcub;run_ref&rcub;/outputs
GET  /runs/&lcub;run_ref&rcub;/runtime</code></pre>
          </article>
        </div>
      </section>

      <section class="section section-alt">
        <div class="section-heading">
          <p class="eyebrow">Quickstart</p>
          <h2>Install once, then keep the path short.</h2>
          <p class="section-copy">
            Install Linkar as a CLI tool, then start a project, attach a pack, run one template,
            and inspect the recorded result.
          </p>
        </div>

        <div class="split-grid">
          <div class="content-card">
            <h3>0. Install Linkar</h3>
            <pre><code>pipx install git+https://github.com/jovesus/linkar.git

# or
uv tool install git+https://github.com/jovesus/linkar.git</code></pre>
          </div>

          <div class="content-card">
            <h3>1. Start a project</h3>
            <pre><code>linkar project init --name demo
cd demo</code></pre>
          </div>

          <div class="content-card">
            <h3>2. Add a pack</h3>
            <pre><code>linkar pack add ~/github/izkf_genomics_pack --id izkf
linkar templates</code></pre>
          </div>

          <div class="content-card">
            <h3>3. Run a template</h3>
            <pre><code>linkar run fastqc --input sample.fastq.gz
linkar project runs</code></pre>
          </div>

          <div class="content-card">
            <h3>4. Inspect the run</h3>
            <pre><code>linkar inspect run fastqc_001

demo/
  fastqc/
  .linkar/
    runs/
      fastqc_001/</code></pre>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-heading">
          <p class="eyebrow">Where To Go Next</p>
          <h2>Use the site by page, not by section.</h2>
          <p class="section-copy">
            The homepage should introduce the model. The real learning and reference material now
            lives in dedicated pages.
          </p>
        </div>
        <div class="card-grid two-up">
          {tutorials.map((entry) => (
            <a class="tutorial-card tutorial-link" href={tutorialHref(entry.slug)}>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description}</p>
              <span class="status-tag">{entry.data.status}</span>
            </a>
          ))}
        </div>
        <div class="card-grid two-up section-top-gap">
          {explanations.map((entry) => (
            <a class="doc-card" href={explanationHref(entry.slug)}>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description}</p>
            </a>
          ))}
        </div>
        <div class="hero-actions section-top-gap">
          <a class="button button-primary" href={`${import.meta.env.BASE_URL}tutorials/`}>Browse tutorials</a>
          <a class="button button-secondary" href={`${import.meta.env.BASE_URL}reference/`}>Open reference</a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
