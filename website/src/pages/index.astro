---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";

const tutorials = (await getCollection("tutorials")).sort((a, b) => a.data.order - b.data.order);
const explanations = (await getCollection("explanations")).sort((a, b) => a.data.order - b.data.order);
const tutorialHref = (slug: string) => `${import.meta.env.BASE_URL}tutorials/${slug}/`;
const explanationHref = (slug: string) => `${import.meta.env.BASE_URL}explanations/${slug}/`;
const docs = [
  { title: "Vision", description: "Problem statement, product thesis, and philosophy.", href: "https://github.com/jovesus/linkar/blob/main/docs/dev/01_vision_and_philosophy.md" },
  { title: "Template Spec", description: "Template contract, metadata, and source-file conventions.", href: "https://github.com/jovesus/linkar/blob/main/docs/dev/04_template_specification.md" },
  { title: "Project Spec", description: "Project structure, pack selection, and run indexing.", href: "https://github.com/jovesus/linkar/blob/main/docs/dev/05_project_specification.md" },
  { title: "CLI Design", description: "CLI principles, pack scopes, and command behavior.", href: "https://github.com/jovesus/linkar/blob/main/docs/dev/15_cli_design.md" },
  { title: "Example Workflows", description: "Concrete workflows to turn into end-user tutorials.", href: "https://github.com/jovesus/linkar/blob/main/docs/dev/19_example_workflows.md" },
  { title: "Roadmap", description: "Development phases and implementation progress.", href: "https://github.com/jovesus/linkar/blob/main/docs/dev/20_future_roadmap.md" },
];
---

<BaseLayout
  title="Linkar | Template Runtime For Humans And Agents"
  description="Linkar is a lightweight runtime for reusable computational templates, with a human-friendly CLI, a local API, and transparent run artifacts designed for reliable AI-agent use."
>
  <div class="page-shell">
    <SiteHeader />

    <main>
      <section id="why" class="section">
        <div class="section-heading">
          <p class="eyebrow">Why Linkar</p>
          <h2>The space between scripts and workflow engines is a product surface.</h2>
          <p class="section-copy">
            Scripts are easy to start and hard to reuse. Workflow systems are powerful and heavy.
            Linkar keeps the middle simple: reusable templates, readable runs, and enough structure
            for automation.
          </p>
        </div>

        <div class="card-grid three-up">
          <article class="feature-card">
            <h3>Templates stay standalone</h3>
            <p>
              Each template is a normal directory with a small YAML contract and a real entry
              script. Nothing important is hidden in framework internals.
            </p>
          </article>
          <article class="feature-card">
            <h3>Humans get a short CLI</h3>
            <p>
              The common path stays short: discover the current project, expose template params as
              flags, and write readable run artifacts instead of hidden state.
            </p>
          </article>
          <article class="feature-card">
            <h3>Agents get explicit structure</h3>
            <p>
              Every run lives in a normal directory with <code>results/</code>,
              <code>.linkar/meta.json</code>, and runtime details that tools and agents can inspect
              later without shell scraping.
            </p>
          </article>
        </div>
      </section>

      <section id="interfaces" class="section section-dark">
        <div class="section-heading">
          <p class="eyebrow">Interfaces</p>
          <h2>One runtime, two excellent entrypoints.</h2>
          <p class="section-copy">
            Linkar should feel natural in a terminal and just as natural inside automation. The CLI
            and local API are thin skins over the same core behavior.
          </p>
        </div>

        <div class="interface-grid">
          <article class="interface-card">
            <div class="interface-head">
              <span class="interface-tag">Human</span>
              <h3>Short CLI for real work</h3>
            </div>
            <p>
              Discover the current project, expose template params as flags, and keep the command
              path short enough to use every day.
            </p>
            <pre><code>linkar project init --name study
cd study
linkar run fastqc --input sample.fastq.gz
linkar project runs
linkar inspect run fastqc_001</code></pre>
          </article>

          <article class="interface-card">
            <div class="interface-head">
              <span class="interface-tag">Machine</span>
              <h3>Structured API for agents</h3>
            </div>
            <p>
              Inspect templates, run work, and consume outputs through JSON while still writing the
              same on-disk artifacts.
            </p>
            <pre><code>linkar serve --port 8000

GET  /templates
GET  /projects/runs
POST /run
GET  /runs/&lcub;instance_id&rcub;</code></pre>
          </article>
        </div>
      </section>

      <section id="quickstart" class="section section-alt">
        <div class="section-heading">
          <p class="eyebrow">Quickstart</p>
          <h2>The shortest useful path.</h2>
          <p class="section-copy">
            Add a pack, run a template, inspect the result, and keep going.
          </p>
        </div>

        <div class="split-grid">
          <div class="content-card">
            <h3>1. Install and test</h3>
            <pre><code>pixi run test
pixi run cli-help</code></pre>
          </div>

          <div class="content-card">
            <h3>2. Start a project</h3>
            <pre><code>linkar project init --name demo
cd demo</code></pre>
          </div>

          <div class="content-card">
            <h3>3. Add a pack</h3>
            <pre><code>linkar config pack add ~/github/izkf_genomics_pack
linkar templates</code></pre>
          </div>

          <div class="content-card">
            <h3>4. Run a template</h3>
            <pre><code>linkar run fastqc --input sample.fastq.gz
linkar project runs
linkar inspect run fastqc_001</code></pre>
          </div>
        </div>
      </section>

      <section id="workflow" class="section">
        <div class="section-heading">
          <p class="eyebrow">Mental Model</p>
          <h2>Three layers, one runtime.</h2>
          <p class="section-copy">
            Templates define one step. Packs distribute them. Projects record what actually ran.
          </p>
        </div>

        <div class="workflow-strip">
          <div class="workflow-step">
            <span class="step-index">01</span>
            <h3>Template</h3>
            <p>Atomic reusable unit with a declared interface and a runnable source script.</p>
          </div>
          <div class="workflow-step">
            <span class="step-index">02</span>
            <h3>Pack</h3>
            <p>Purposeful collection of templates and optional binding defaults.</p>
          </div>
          <div class="workflow-step">
            <span class="step-index">03</span>
            <h3>Project</h3>
            <p>Local run index that tracks outputs, provenance, and active pack choices.</p>
          </div>
        </div>

        <div class="terminal-window workflow-terminal">
          <div class="terminal-bar">
            <span></span><span></span><span></span>
          </div>
          <pre><code>study/
  project.yaml
  fastqc_001/
    run.sh
    results/
    .linkar/
      meta.json
      runtime.json</code></pre>
        </div>

        <div class="card-grid two-up">
          <article class="feature-card">
            <h3>Human interface</h3>
            <p>A thin CLI with project discovery, readable commands, and inspectable local state.</p>
          </article>
          <article class="feature-card">
            <h3>Machine interface</h3>
            <p>A thin core and local API with structured params, outputs, and metadata.</p>
          </article>
        </div>
      </section>

      <section id="proof" class="section section-alt">
        <div class="section-heading">
          <p class="eyebrow">Why It Matters</p>
          <h2>Designed for high-trust execution records.</h2>
          <p class="section-copy">
            The goal is not only to run something once. The goal is to make that run usable later
            by a colleague, by your future self, or by an AI system.
          </p>
        </div>

        <div class="proof-grid">
          <article class="proof-card">
            <span class="proof-index">01</span>
            <h3>Clear contracts</h3>
            <p><code>linkar_template.yaml</code> declares params, outputs, and the real entrypoint.</p>
          </article>
          <article class="proof-card">
            <span class="proof-index">02</span>
            <h3>Portable runs</h3>
            <p>Every execution leaves behind results, metadata, and runtime facts in one place.</p>
          </article>
          <article class="proof-card">
            <span class="proof-index">03</span>
            <h3>Lightweight chaining</h3>
            <p>Templates connect through recorded outputs and bindings, not a heavyweight DAG language.</p>
          </article>
          <article class="proof-card">
            <span class="proof-index">04</span>
            <h3>Agent-ready structure</h3>
            <p>The same core semantics are available through Python helpers, the CLI, and the local API.</p>
          </article>
        </div>
      </section>

      <section id="tutorials" class="section section-alt">
        <div class="section-heading">
          <p class="eyebrow">Tutorials</p>
          <h2>Practical guides for users and pack authors.</h2>
          <p class="section-copy">
            Start with the basic project flow, then move into template authoring, packs, and agent use.
          </p>
        </div>

        <div class="card-grid two-up">
          {tutorials.map((entry) => (
            <a class="tutorial-card tutorial-link" href={tutorialHref(entry.slug)}>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description}</p>
              <span class="status-tag">{entry.data.status}</span>
            </a>
          ))}
        </div>
      </section>

      <section id="examples" class="section">
        <div class="section-heading">
          <p class="eyebrow">Examples</p>
          <h2>Use the bundled packs as a progression.</h2>
          <p class="section-copy">
            The examples move from the smallest shell template to chaining, binding overrides, and
            remote asset references.
          </p>
        </div>

        <div class="card-grid two-up">
          <article class="feature-card">
            <h3>Basic pack</h3>
            <p>
              Start with `simple_echo`, then move through file inputs, explicit defaults, light
              downloads, FASTQ summaries, and pixi-backed templates.
            </p>
          </article>
          <article class="feature-card">
            <h3>Chaining and beyond</h3>
            <p>
              Continue with `examples/packs/chaining`, then inspect `pack_management` and `remote`
              for active-pack selection and Git-backed assets.
            </p>
          </article>
        </div>
      </section>

      <section id="docs" class="section">
        <div class="section-heading">
          <p class="eyebrow">Reference</p>
          <h2>Specs, rationale, and design notes.</h2>
          <p class="section-copy">
            Linkar is meant to be inspectable all the way down. The docs explain the model, the
            contracts, and the long-term direction in plain language.
          </p>
        </div>

        <div class="card-grid two-up">
          {explanations.map((entry) => (
            <a class="doc-card" href={explanationHref(entry.slug)}>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description}</p>
            </a>
          ))}
        </div>

        <div class="section-heading docs-secondary-heading">
          <p class="eyebrow">Spec Set</p>
          <h2>Existing development docs.</h2>
        </div>

        <div class="doc-grid">
          {docs.map((doc) => (
            <a class="doc-card" href={doc.href}>
              <h3>{doc.title}</h3>
              <p>{doc.description}</p>
            </a>
          ))}
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
