---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";

const tutorials = (await getCollection("tutorials")).sort((a, b) => a.data.order - b.data.order);
const tutorialHref = (slug: string) => `${import.meta.env.BASE_URL}tutorials/${slug}/`;
---

<BaseLayout title="Tutorials | Linkar" description="Step-by-step Linkar guides for starting projects, authoring templates, testing packs, and using Linkar from agents.">
  <div class="page-shell">
    <SiteNav />
    <main class="section-page">
      <section class="page-hero">
        <p class="eyebrow">Tutorials</p>
        <h1 class="page-title">Learn Linkar one path at a time.</h1>
        <p class="lede page-lede">
          Start with the shortest local project flow, then move into authoring, testing, packs,
          and agent-oriented usage.
        </p>
      </section>

      <section class="section page-section-tight">
        <div class="split-grid">
          <article class="content-card">
            <h3>Start here</h3>
            <p>
              Read <a href={tutorialHref("getting-started")}>Getting started with a local project</a>
              first. It shows the normal human path: initialize a project, attach a pack, run one
              template, and inspect the result.
            </p>
          </article>
          <article class="content-card">
            <h3>Then pick a lane</h3>
            <p>
              Template authors should continue with authoring and testing. Users adopting shared
              packs should continue with packs, scope, and the bundled example packs.
            </p>
          </article>
        </div>
      </section>

      <section class="section page-section-tight">
        <div class="card-grid two-up">
          {tutorials.map((entry) => (
            <a class="tutorial-card tutorial-link" href={tutorialHref(entry.slug)}>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.description}</p>
              <span class="status-tag">{entry.data.status}</span>
            </a>
          ))}
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
