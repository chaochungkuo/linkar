---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Examples | Linkar" description="Choose the right bundled Linkar example pack based on what you want to learn: basic template authoring, chaining, binding overrides, pack selection, or remote packs.">
  <div class="page-shell">
    <SiteNav />
    <main class="section-page">
      <section class="page-hero">
        <p class="eyebrow">Examples</p>
        <h1 class="page-title">Bundled packs you can read and run.</h1>
        <p class="lede page-lede">
          Pick the smallest example that answers your question.
        </p>
      </section>

      <section class="section page-section-tight">
        <div class="card-grid two-up">
          <a class="doc-card" href={`${base}tutorials/testing-basic-templates/`}>
            <div class="card-tags">
              <span class="card-tag">Authoring</span>
            </div>
            <h3>Basic</h3>
            <p>
              Start here for the template contract: `run.command`, `run.sh`, `run.py`, declared
              outputs, `glob` outputs, `tools.required_any`, file inputs, and local tests.
            </p>
          </a>

          <a class="doc-card" href={`${base}tutorials/example-pack-progression/#2-learn-pack-level-chaining-with-chaining`}>
            <div class="card-tags">
              <span class="card-tag">Bindings</span>
            </div>
            <h3>Chaining</h3>
            <p>
              Open this when you want to see pack-level default binding in action. The key lesson is
              that template-to-template connection lives in the pack, not in manual operator steps.
            </p>
          </a>

          <a class="doc-card" href={`${base}tutorials/example-pack-progression/#3-compare-defaults-and-caller-overrides-with-binding_overrides`}>
            <div class="card-tags">
              <span class="card-tag">Bindings</span>
            </div>
            <h3>Binding overrides</h3>
            <p>
              Use this when you want to compare three things directly: project history, a pack's
              default binding, and an explicit override binding passed by the caller.
            </p>
          </a>

          <a class="doc-card" href={`${base}tutorials/example-pack-progression/#4-learn-pack-selection-with-pack_management`}>
            <div class="card-tags">
              <span class="card-tag">Pack Selection</span>
            </div>
            <h3>Pack management</h3>
            <p>
              Use this when multiple packs expose the same template id and you want to see how
              active-pack selection and `--pack` keep resolution explicit.
            </p>
          </a>

          <a class="doc-card" href={`${base}tutorials/example-pack-progression/#5-learn-remote-pack-references-with-remote`}>
            <div class="card-tags">
              <span class="card-tag">Remote</span>
            </div>
            <h3>Remote</h3>
            <p>
              Use this once local packs are clear and you want to see `git+` references, cached
              remote assets, and revision-aware provenance.
            </p>
          </a>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>
